# ============================================================
# CAMBORIU ESTUDIANTIL — Variables de Entorno
# ============================================================
# Copiá este archivo como .env.local y completá los valores
# cp .env.example .env.local

# ------------------------------------------------------------
# SUPABASE
# Obtené estos valores en: supabase.com → tu proyecto → Settings → API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------------------------------------------------------------
# CLOUDINARY
# Obtené estos valores en: cloudinary.com → Dashboard
# ------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=tu_api_secret_aqui
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=camboriu_unsigned

# ------------------------------------------------------------
# ADMIN
# Email del administrador principal (para acceso al panel)
# ------------------------------------------------------------
ADMIN_EMAIL=admin@camboriuestudiantil.com

# ------------------------------------------------------------
# WHATSAPP
# Número sin espacios ni +, solo dígitos (ej: 5547992816769)
# ------------------------------------------------------------
NEXT_PUBLIC_WHATSAPP_NUMBER=5547992816769

# ------------------------------------------------------------
# SITE URL (para Open Graph, PWA manifest, etc.)
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://camboriuestudiantil.com
